rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if hasRole('ADMIN');
    }

    // Loan Applications
    match /applications/{appId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Any staff can create
      
      allow update: if isSignedIn() && (
        // Team Lead can approve Tier 1 -> Tier 2
        (hasRole('TEAM_LEAD') && request.resource.data.status == 'PENDING_CREDIT') ||
        // Credit Analyst can approve Tier 2 -> Tier 3
        (hasRole('CREDIT') && request.resource.data.status == 'PENDING_LEGAL') ||
        // Legal can finalize
        (hasRole('LEGAL') && request.resource.data.status == 'APPROVED') ||
        // Any tier can reject/request changes
        (hasRole('TEAM_LEAD') || hasRole('CREDIT') || hasRole('LEGAL')) && 
        (request.resource.data.status == 'REJECTED' || request.resource.data.status == 'NEEDS_CHANGES')
      );
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow write: if hasRole('ADMIN') || hasRole('TEAM_LEAD') || hasRole('CREDIT') || hasRole('LEGAL');
    }

    // Global Activity log
    match /activity/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
